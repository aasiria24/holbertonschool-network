#!/usr/bin/env bash
# Configures /etc/hosts so localhost resolves to 127.0.0.2 and facebook.com to 8.8.8.8
cp /etc/hosts /tmp/hosts_temp
sed 's/127.0.0.1\s*localhost/127.0.0.2 localhost/' /tmp/hosts_temp > /tmp/hosts_new
if grep -q "facebook.com" /tmp/hosts_new; then
    sed -i 's/.*facebook.com.*/8.8.8.8 facebook.com/' /tmp/hosts_new
else
    echo "8.8.8.8 facebook.com" >> /tmp/hosts_new
fi
cp /tmp/hosts_new /etc/hosts
